#!/usr/bin/env bash

# ssh-context: sourced by hostname, username, create
# Sets: pane_tty, tty_commands, foreground, is_ssh, ssh_host, cache_dir, tty_key

if test -n "$1"; then
	pane_tty="$1"
else
	pane_tty=$(tmux display -p '#{pane_tty}')
fi

if [[ "$(uname)" == "Darwin" ]]; then
	readarray -t tty_commands < <(ps -t "$pane_tty" -o user=,args=)
else
	readarray -t tty_commands < <(ps -t "$pane_tty" -o user:30=,args=)
fi

foreground="${tty_commands[-1]}"
is_ssh=false
ssh_host=""

_first_ssh_cmd=""
for _cmd in "${tty_commands[@]}"; do
	_cmd_args=$(awk '{$1=""; sub(/^ /,"")}1' <<< "$_cmd")
	if grep -qE "(^|/)ssh\s+" <<< "$_cmd_args"; then
		_first_ssh_cmd="$_cmd_args"
		break
	fi
done

if [[ -n "$_first_ssh_cmd" ]]; then
	is_ssh=true
	ssh_host=$(echo "$_first_ssh_cmd" | awk '
		BEGIN { skip=0 }
		{
			for (i=2; i<=NF; i++) {
				if (skip) { skip=0; continue }
				if ($i ~ /^-[bcDEeFIiJLlmOopQRSwX]$/) { skip=1; continue }
				if ($i ~ /^-/) { continue }
				print $i; exit
			}
		}
	')
fi

cache_dir="${TMPDIR:-/tmp}/tmux-statusbar"
mkdir -p "$cache_dir"
tty_key=$(sed 's,/,_,g' <<< "$pane_tty")
