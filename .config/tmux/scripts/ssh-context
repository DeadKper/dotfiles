#!/usr/bin/env bash

# ssh-context: sourced by hostname, username, create
# Sets: pane_tty, tty_commands, foreground, is_ssh, ssh_host, pane_id, pane_key
# Manages: TMUX_${pane_key}_SSH_CMD, invalidates _USER/_HOST on foreground change

if test -n "$1"; then
	pane_tty="$1"
else
	pane_tty=$(tmux display -p '#{pane_tty}')
fi

pane_id=$(tmux display -p '#{pane_id}' 2>&1)
pane_key="${pane_id#%}"

if [[ "$(uname)" == "Darwin" ]]; then
	readarray -t tty_commands < <(ps -t "$pane_tty" -o user=,args=)
else
	readarray -t tty_commands < <(ps -t "$pane_tty" -o user:30=,args=)
fi

foreground="${tty_commands[-1]}"
is_ssh=false
ssh_host=""

first_ssh_cmd=""
for cmd in "${tty_commands[@]}"; do
	cmd_args=$(awk '{$1=""; sub(/^ /,"")}1' <<< "$cmd")
	if grep -qE "(^|/)ssh\s+" <<< "$cmd_args"; then
		first_ssh_cmd="$cmd_args"
		break
	fi
done

if [[ -n "$first_ssh_cmd" ]]; then
	is_ssh=true
	ssh_host=$(echo "$first_ssh_cmd" | awk '
		BEGIN { skip=0 }
		{
			for (i=2; i<=NF; i++) {
				if (skip) { skip=0; continue }
				if ($i ~ /^-[bcDEeFIiJLlmOopQRSwX]$/) { skip=1; continue }
				if ($i ~ /^-/) { continue }
				print $i; exit
			}
		}
	')
fi

var_prefix="TMUX_${pane_key}"
if [[ -n "$pane_id" ]]; then
	prev_cmd=$(tmux show-environment "${var_prefix}_SSH_CMD" 2>/dev/null | sed 's/^[^=]*=//')
	if [[ "$prev_cmd" != "$foreground" ]]; then
		if is_ssh; then
			tmux set-environment    "${var_prefix}_SSH_CMD" "$foreground"
		else
			tmux set-environment -u "${var_prefix}_SSH_CMD" 2>/dev/null || true
		fi
		tmux set-environment -u "${var_prefix}_SSH_USER" 2>/dev/null || true
		tmux set-environment -u "${var_prefix}_SSH_HOST" 2>/dev/null || true
	fi
fi
