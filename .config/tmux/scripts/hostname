#!/usr/bin/env bash
if [ "$(uname)" = "Darwin" ] && [ "${BASH_VERSINFO[0]:-0}" -lt 4 ]; then
	exec /opt/homebrew/bin/bash "$0" "$@"
fi

. "$(dirname "$0")/ssh-context"

if $is_ssh; then
	cached_val=$(tmux show-environment "TMUX_${pane_key}_SSH_HOST" 2>/dev/null | sed 's/^[^=]*=//')
	if [[ -n "$cached_val" ]]; then
		echo "$cached_val"
		exit 0
	fi
fi

get_hostname() {
	local hostname=""
	if $is_ssh; then
		if grep -qwF 'cyberark.cloud' <<< "$ssh_host"; then
			hostname=$(ssh -qG "$ssh_host" | awk '/^user / {print $2}' | awk -F@ '{print $4}' | sed -E 's/#\w+$//')
		elif grep -qwF 'coppel.cloud' <<< "$ssh_host"; then
			hostname=$(ssh -qG "$ssh_host" | awk '/^hostname / {print $2}' | sed -E 's/#\w+$//')
		else
			hostname=$(ssh -qG "$ssh_host" | awk '/^hostname / { print $2; exit }')
		fi
	fi
	if test -z "$hostname"; then
		[[ "$(uname)" == "Darwin" ]] && hostname -s || cat /etc/hostname
	else
		echo "$hostname"
	fi
}

result=$(get_hostname)
if $is_ssh; then
	tmux set-environment "TMUX_${pane_key}_SSH_HOST" "$result"
fi
echo "$result"
