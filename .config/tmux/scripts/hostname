#!/usr/bin/env bash
if [ "$(uname)" = "Darwin" ] && [ "${BASH_VERSINFO[0]:-0}" -lt 4 ]; then
	exec /opt/homebrew/bin/bash "$0" "$@"
fi

. "$(dirname "$0")/ssh-context"

if $is_ssh; then
	_cached_cmd=$(tmux show-environment -t "$pane_id" TMUX_HOSTNAME_CMD 2>/dev/null | sed 's/^[^=]*=//')
	_cached_val=$(tmux show-environment -t "$pane_id" TMUX_HOSTNAME_VAL 2>/dev/null | sed 's/^[^=]*=//')
	if [[ "$_cached_cmd" == "$foreground" && -n "$_cached_val" ]]; then
		echo "$_cached_val"
		exit 0
	fi
fi

get_hostname() {
	local hostname=""
	if $is_ssh; then
		if grep -qwF 'cyberark.cloud' <<< "$ssh_host"; then
			hostname=$(ssh -qG "$ssh_host" | awk '/^user / {print $2}' | awk -F@ '{print $4}' | sed -E 's/#\w+$//')
		elif grep -qwF 'coppel.cloud' <<< "$ssh_host"; then
			hostname=$(ssh -qG "$ssh_host" | awk '/^hostname / {print $2}' | sed -E 's/#\w+$//')
		else
			hostname=$(ssh -qG "$ssh_host" | awk '/^hostname / { print $2; exit }')
		fi
	fi
	if test -z "$hostname"; then
		[[ "$(uname)" == "Darwin" ]] && hostname -s || cat /etc/hostname
	else
		echo "$hostname"
	fi
}

result=$(get_hostname)
if $is_ssh; then
	tmux set-environment -t "$pane_id" TMUX_HOSTNAME_CMD "$foreground"
	tmux set-environment -t "$pane_id" TMUX_HOSTNAME_VAL "$result"
fi
echo "$result"
