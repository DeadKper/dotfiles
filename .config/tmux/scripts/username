#!/usr/bin/env bash
if [ "$(uname)" = "Darwin" ] && [ "${BASH_VERSINFO[0]:-0}" -lt 4 ]; then
	exec /opt/homebrew/bin/bash "$0" "$@"
fi

. "$(dirname "$0")/ssh-context"

if $is_ssh; then
	_cached_cmd=$(tmux show-environment -t "$pane_id" TMUX_USERNAME_CMD 2>/dev/null | sed 's/^[^=]*=//')
	_cached_val=$(tmux show-environment -t "$pane_id" TMUX_USERNAME_VAL 2>/dev/null | sed 's/^[^=]*=//')
	if [[ "$_cached_cmd" == "$foreground" && -n "$_cached_val" ]]; then
		echo "$_cached_val"
		exit 0
	fi
fi

get_username() {
	local username=""
	if $is_ssh; then
		if grep -qwE 'cyberark\.cloud|coppel\.cloud' <<< "$ssh_host"; then
			username=$(ssh -qG "$ssh_host" | awk '/^user / {print $2}' | awk -F@ '{print $3}')
		else
			username=$(ssh -qG "$ssh_host" | awk '/^user / {print $2}')
		fi
	fi
	if test -z "$username"; then
		echo "${tty_commands[-1]}" | awk '{print $1}'
	else
		echo "$username"
	fi
}

result=$(get_username)
if $is_ssh; then
	tmux set-environment -t "$pane_id" TMUX_USERNAME_CMD "$foreground"
	tmux set-environment -t "$pane_id" TMUX_USERNAME_VAL "$result"
fi
echo "$result"
